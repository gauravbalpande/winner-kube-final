---
# ============================================================
# Secret — Sensitive credentials (EXAMPLE TEMPLATE ONLY)
# ⚠️  NEVER commit real values to Git!
#
# Create the secret from GitHub Actions:
#   kubectl create secret generic betmasterx-secrets \
#     --namespace=betmasterx \
#     --from-literal=SUPABASE_URL=${{ secrets.SUPABASE_URL }} \
#     --from-literal=SUPABASE_KEY=${{ secrets.SUPABASE_KEY }} \
#     --from-literal=SUPABASE_SERVICE_KEY=${{ secrets.SUPABASE_SERVICE_KEY }} \
#     --from-literal=SECRET_KEY=${{ secrets.JWT_SECRET }} \
#     --dry-run=client -o yaml | kubectl apply -f -
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: betmasterx-secrets
  namespace: betmasterx
  labels:
    app.kubernetes.io/name: betmasterx
    app.kubernetes.io/component: secrets
type: Opaque
stringData:
  # Replace with base64-encoded values or let kubectl handle encoding
  SUPABASE_URL: "REPLACE_ME"
  SUPABASE_KEY: "REPLACE_ME"
  SUPABASE_SERVICE_KEY: "REPLACE_ME"
  SECRET_KEY: "REPLACE_WITH_STRONG_RANDOM_KEY"
